rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------
    // 0. GLOBAL SAFETY NET
    // -----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------------
    // 1. GLOBAL HELPERS
    // -----------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in [
          "jtothek319@gmail.com", 
          "edubrizzy420@gmail.com", 
          "vixenvile420@gmail.com",
          "vixenvile@gmail.com"
        ] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true)
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isValidDate(d) { return d is string && d.size() >= 10 && d.size() <= 64; }

    // -----------------------------------------------------------------
    // 2. ENTITY VALIDATIONS
    // -----------------------------------------------------------------

    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128 &&
             (data.get('username', '') == '' || (data.username is string && data.username.size() <= 128)) &&
             (data.get('email', '') == '' || (data.email is string && data.email.size() <= 256)) &&
             data.keys().size() <= 150;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['id', 'userId', 'content', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.content is string && data.content.size() <= 20000 &&
             isValidDate(data.createdAt) &&
             data.keys().size() <= 60;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['id', 'postId', 'userId', 'text', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.postId is string && data.postId.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.text is string && data.text.size() <= 2000 &&
             isValidDate(data.createdAt) &&
             data.keys().size() <= 15;
    }

    // -----------------------------------------------------------------
    // 3. COLLECTION RULES
    // -----------------------------------------------------------------

    // USERS
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) && isValidUser(incoming())) || isAdmin() || (
        // Allow partial updates from system/others for relational fields
        isSignedIn() && incoming().diff(existing()).affectedKeys().hasAny([
          'fanIds', 'friendIds', 'subscribersCount', 'followingCount', 
          'pendingFriendRequestsSent', 'pendingFriendRequestsReceived',
          'fwbIds', 'pendingFwbRequestsSent', 'pendingFwbRequestsReceived',
          'fwbRequestsSentCount', 'fwbRequestsResetDate', 'likedPostIds',
          'isStoreActive', 'storeActivationDate', 'isStableActive', 'stableActivationDate'
        ])
      );
      allow delete: if isAdmin();
    }

    // PROFILES (Public mirror)
    match /profiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // POSTS
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && (
        incoming().userId == request.auth.uid || 
        isAdmin() || 
        (incoming().userId == 'ai-jade' && isAdmin())
      ) && isValidPost(incoming());
      
      allow update: if isSignedIn() && (
        (existing().userId == request.auth.uid && isValidPost(incoming())) ||
        isAdmin() ||
        incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'likedBy', 'commentsCount'])
      );
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // MESSAGES
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        existing().senderId == request.auth.uid || 
        existing().receiverId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid && (
        incoming().keys().hasAll(['id', 'senderId', 'receiverId', 'text', 'timestamp'])
      );
      allow update: if isSignedIn() && (
        (existing().receiverId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['isRead'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // STORE ITEMS
    match /storeItems/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        (incoming().userId == request.auth.uid && (
          isAdmin() || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isStoreActive', false) == true
        )) || 
        isAdmin()
      );
      allow update, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn(); // Allow system or other users to send notifications
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // COMMENTS
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin()) && isValidComment(incoming());
      allow update, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // STABLE LISTINGS
    match /stableListings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn() && (
        (incoming().userId == request.auth.uid && (
          isAdmin() || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isStableActive', false) == true
        )) || 
        isAdmin()
      );
      allow update, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // CONNECTION TEST
    match /_connection_test_/{docId} {
      allow read: if true;
    }
  }
}
